# ====== App ======
NODE_ENV=development
PORT=3000
# APP_URL precisa ser publico HTTPS em prod. Em dev, use ngrok e cole aqui:
APP_URL=http://localhost:3000

# ====== Database ======
DATABASE_URL=postgresql://varbolao:senha_segura@localhost:5433/varbolao
POSTGRES_PASSWORD=senha_segura

# ====== Redis ======
REDIS_URL=redis://localhost:6380/0

# ====== Evolution API (WhatsApp) ======
# DRY_RUN_WHATSAPP=true = modo simulacao (testes/REPL local sem WhatsApp real).
DRY_RUN_WHATSAPP=true
EVOLUTION_API_URL=http://localhost:8080
EVOLUTION_API_KEY=substitua_pela_api_key_da_evolution
EVOLUTION_INSTANCE=varbolao
EVOLUTION_WEBHOOK_TOKEN=

# ====== LLM (Ollama Cloud) ======
# Usado como fallback quando o parser regex nao entende a mensagem do
# usuario. Se LLM_ENABLED=false ou a chave for invalida, o bot continua
# funcional — so cai pro "nao entendi" mais rapido.
LLM_ENABLED=true
LLM_URL=https://ollama.com
LLM_API_KEY=substitua_pela_chave_da_ollama_cloud
LLM_MODEL=gpt-oss:20b
LLM_TIMEOUT_MS=5000

# ====== API de Futebol ======
FOOTBALL_PROVIDER=fifa-2026
FOOTBALL_API_KEY=mock
FOOTBALL_API_URL=https://www.api-futebol.com.br/v1
# Opcional: ID da temporada na API publica da FIFA pra puxar placares ao vivo
# Sem isso, o sistema seedea os jogos mas nao atualiza placares automaticamente
FIFA_SEASON_ID=

# ====== PIX (DESATIVADO — bolao esta gratuito) ======
PIX_PROVIDER=mock
PIX_ACCESS_TOKEN=
PIX_CHAVE=contato@vardobolao.com.br
PIX_VALOR_CENTAVOS=0

# ====== Bot ======
BOT_PREFIX=!
TIMEZONE=America/Sao_Paulo
DEFAULT_CAMPEONATO=copa-2026-fase-grupos
# "Bom dia boleiros" diario nos dias com jogo:
# Se HORARIO_BOM_DIA cair DEPOIS de (kickoff - 8h), o bom dia eh deslocado
# pra (kickoff - 6h) — assim ninguem perde o saudar antes do jogo cedo.
HORARIO_BOM_DIA=09:00
# Quantas horas antes do primeiro jogo do dia disparar a chamada de palpites
PALPITE_CALL_HORAS_ANTES=6

# ====== Web API (site vardobolao.com.br) — Fase 2 do PLANO_SITE ======
# WEB_API_ENABLED=false (default) = bot identico ao binario antigo.
# Liga em prod quando quiser expor a area logada do site.
WEB_API_ENABLED=false
# Origem do site permitida no CORS. Pode listar varias separadas por virgula.
WEB_ORIGIN=http://localhost:3001
# Segredo HMAC compartilhado entre Next e Fastify. MINIMO 32 bytes hex.
# Gerar com: openssl rand -hex 32
WEB_SESSION_SECRET=dev-only-change-in-prod-min-32-bytes-hex-secret-please
WEB_SESSION_TTL_DAYS=30

# OTP via WhatsApp (manda codigo de 6 digitos via Evolution)
OTP_VALIDITY_MINUTES=10
OTP_MAX_ATTEMPTS=5
OTP_RATE_LIMIT_PER_MINUTE=1
OTP_RATE_LIMIT_PER_DAY=5
