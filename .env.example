# ====== App ======
NODE_ENV=development
PORT=3000
# APP_URL precisa ser publico HTTPS em prod. Em dev, use ngrok e cole aqui:
APP_URL=http://localhost:3000

# ====== Database ======
DATABASE_URL=postgresql://varbolao:senha_segura@localhost:5433/varbolao
POSTGRES_PASSWORD=senha_segura

# ====== Redis ======
REDIS_URL=redis://localhost:6380/0

# ====== Meta WhatsApp Cloud API ======
# Obtenha em: https://developers.facebook.com/apps → WhatsApp → Getting Started
WHATSAPP_ACCESS_TOKEN=substitua_pelo_token_permanente_do_meta
WHATSAPP_PHONE_NUMBER_ID=substitua_pelo_phone_number_id
WHATSAPP_VERIFY_TOKEN=escolha_uma_string_qualquer_aqui
WHATSAPP_APP_SECRET=substitua_pelo_app_secret_do_meta
WHATSAPP_API_VERSION=v18.0

# ====== API de Futebol ======
# "mock" = usa adapter fake. Qualquer outro valor = usa a API real em FOOTBALL_API_URL
FOOTBALL_API_KEY=mock
FOOTBALL_API_URL=https://www.api-futebol.com.br/v1

# ====== PIX ======
# "mock" = auto-aprova em ~45s pra testes. "mercadopago" | "gerencianet" = real (WIP)
PIX_PROVIDER=mock
PIX_ACCESS_TOKEN=
PIX_CHAVE=varbolao@exemplo.com
PIX_VALOR_CENTAVOS=9990

# ====== Bot ======
BOT_PREFIX=!
TIMEZONE=America/Sao_Paulo
DEFAULT_CAMPEONATO=brasileirao-serie-a
HORARIO_ENVIO_JOGOS_DIA=09:00
