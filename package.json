{
  "name": "var-do-bolao",
  "version": "2.0.0",
  "description": "Bot de WhatsApp (Meta Cloud API) para gerenciar bolões de futebol — o árbitro digital em DM",
  "type": "module",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "sim": "cross-env DRY_RUN_WHATSAPP=true tsx scripts/sim.ts",
    "seed:fifa": "tsx scripts/seed-fifa-2026.ts",
    "seed:mata-mata": "tsx scripts/seed-mata-mata.ts",
    "sync:copa-2026": "node scripts/sync-copa-2026.mjs",
    "audit:prompts": "node scripts/audit-prompts.mjs",
    "build": "tsc && node scripts/postbuild.mjs",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "db:migrate": "prisma migrate dev",
    "db:push": "prisma db push",
    "db:studio": "prisma studio",
    "db:generate": "prisma generate",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@prisma/client": "^6.6.0",
    "bcryptjs": "^2.4.3",
    "bullmq": "^5.34.0",
    "dotenv": "^17.4.2",
    "fastify": "^5.3.0",
    "ioredis": "^5.6.0",
    "node-cron": "^3.0.3",
    "sharp": "^0.33.3",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^22.0.0",
    "@types/node-cron": "^3.0.11",
    "cross-env": "^7.0.3",
    "prisma": "^6.6.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^3.1.0"
  }
}
