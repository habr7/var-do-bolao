# ====== App ======
NODE_ENV=development
PORT=3000
# APP_URL precisa ser publico HTTPS em prod. Em dev, use ngrok e cole aqui:
APP_URL=http://localhost:3000

# ====== Database ======
DATABASE_URL=postgresql://varbolao:senha_segura@localhost:5433/varbolao
POSTGRES_PASSWORD=senha_segura

# ====== Redis ======
REDIS_URL=redis://localhost:6380/0

# ====== Evolution API (WhatsApp) ======
# DRY_RUN_WHATSAPP=true = modo simulacao (testes/REPL local sem WhatsApp real).
DRY_RUN_WHATSAPP=true
EVOLUTION_API_URL=http://localhost:8080
EVOLUTION_API_KEY=substitua_pela_api_key_da_evolution
EVOLUTION_INSTANCE=varbolao
EVOLUTION_WEBHOOK_TOKEN=

# ====== LLM (Ollama Cloud) ======
# Usado como fallback quando o parser regex nao entende a mensagem do
# usuario. Se LLM_ENABLED=false ou a chave for invalida, o bot continua
# funcional — so cai pro "nao entendi" mais rapido.
LLM_ENABLED=true
LLM_URL=https://ollama.com
LLM_API_KEY=substitua_pela_chave_da_ollama_cloud
LLM_MODEL=gpt-oss:20b
# Bump pra 8s — Gemini sob carga responde em 4-7s as vezes.
# 5s causava timeout precoce com Gemini retornando HTTP 503.
LLM_TIMEOUT_MS=8000

# ====== Observabilidade (Sprint 3) ======
# Retencao em dias pras mensagens nao entendidas (tabela mensagens_nao_entendidas).
# Job mensal limpa registros mais antigos que isso. Default 180 dias (~6 meses).
MENSAGEM_NAO_ENTENDIDA_RETENCAO_DIAS=180

# ====== API de Futebol ======
# v3.22.0: default agora eh 'hybrid' (RECOMENDADO).
#   - hybrid: FIFA (api.fifa.com, AO VIVO) primario + openfootball como
#     fallback automatico se a FIFA cair. Sem API key.
#   - openfootball: so JSON publico — sem API key, latencia ~30-60min,
#     SEM placar ao vivo. Mesma fonte do sync-copa-2026.mjs.
#   - fifa-2026: so api.fifa.com — AO VIVO; usa FIFA_SEASON_ID (default 285023).
#   - mock: 3 jogos fixos pra dev.
FOOTBALL_PROVIDER=hybrid
FOOTBALL_API_KEY=mock
FOOTBALL_API_URL=https://www.api-futebol.com.br/v1
# IdSeason da Copa na api.fifa.com. Default = FIFA World Cup 2026 (285023),
# confirmado em /api/v3/seasons?idCompetition=17. So mude se a FIFA mudar.
FIFA_SEASON_ID=285023

# ====== PIX (DESATIVADO — bolao esta gratuito) ======
PIX_PROVIDER=mock
PIX_ACCESS_TOKEN=
PIX_CHAVE=contato@vardobolao.com.br
PIX_VALOR_CENTAVOS=0

# ====== Bot ======
BOT_PREFIX=!
TIMEZONE=America/Sao_Paulo
DEFAULT_CAMPEONATO=copa-2026-fase-grupos
# "Bom dia boleiros" — v3.36.0: dispara em HORA FIXA (BRT), uma vez/dia, pra
# TODOS os participantes com jogo nas proximas ~30h (lista com palpitado/falta).
HORARIO_BOM_DIA=09:00
# Chamada de palpites (6h antes do 1o jogo). v3.36.0: DESATIVADA por padrao —
# redundante com bom-dia (9h) + lembrete de 30min. Re-ative com ENABLE_PALPITE_CALL=true.
# ENABLE_PALPITE_CALL=true
PALPITE_CALL_HORAS_ANTES=6
# v3.24.0 — revelação de palpites no kickoff (push). Quando o jogo começa,
# manda pros integrantes os palpites de todos do bolão pra aquele jogo.
ENABLE_PALPITE_REVEAL=true
# v3.17.0 — cap absoluto de avisos por user por dia (cross-job).
# Caso real Camila 11/06: bom-dia + palpite-call + reminder = 3 msgs em 3.5h.
# v3.24.0: subido 2 → 8 porque a revelação de palpites no kickoff CONTA neste
# cap e em dia de fase de grupos há até ~4 jogos. A resposta sob demanda
# ("quais os palpites de todos?") NÃO conta.
MAX_AVISOS_DIA=8

# ====== Revisao diaria (v3.32.0) ======
# 1x/dia (09:00 BRT) manda pro(s) OWNER_WHATSAPP_IDS o relatorio das
# mensagens nao-entendidas das ultimas 24h (loop de melhoria continua).
ENABLE_REVISAO_DIARIA=true

# ====== Lembrete de 30 min por jogo (v3.31.0) ======
# Cutuca quem nao palpitou um jogo quando falta ~30 min pro kickoff.
# Substitui o ENABLE_REMINDERS (por-rodada), que fica desativado por padrao.
ENABLE_LEMBRETE_30MIN=true
LEMBRETE_30MIN_ANTECEDENCIA_MIN=30
# Cooldown por usuario (min): no max. 1 lembrete-de-ultima-hora por janela.
LEMBRETE_30MIN_COOLDOWN_MIN=90
# Lembrete por-rodada antigo (substituido). Deixe vazio/ausente pra manter off.
# ENABLE_REMINDERS=false

# ====== Broadcast administrativo (v3.26.0) ======
# Numero(s) dono(s) que podem disparar broadcast (lista por virgula, so digitos).
OWNER_WHATSAPP_IDS=5511976135412
# Modo teste: TRUE = envia SO pro proprio dono que disparou (valida o fluxo).
# Trocar pra false SO depois de validar — e com EVOLUTION_WEBHOOK_TOKEN setado.
BROADCAST_TEST_MODE=true
# Marcador no inicio da mensagem que abre o comando de broadcast.
BROADCAST_MARKER=#ENVIOPARAVARDOBOLAO#
# Delay (ms) entre envios — protege contra ban/rate-limit do WhatsApp.
BROADCAST_THROTTLE_MS=1000
