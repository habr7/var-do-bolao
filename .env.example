# ====== App ======
NODE_ENV=development
PORT=3000
# APP_URL precisa ser publico HTTPS em prod (dominio da Evolution recebendo
# webhook que chama de volta sua app). Em dev, use ngrok e cole aqui:
APP_URL=http://localhost:3000

# ====== Database ======
DATABASE_URL=postgresql://varbolao:senha_segura@localhost:5433/varbolao
POSTGRES_PASSWORD=senha_segura

# ====== Redis ======
REDIS_URL=redis://localhost:6380/0

# ====== Evolution API (WhatsApp) ======
# DRY_RUN_WHATSAPP=true = modo simulacao (testes/REPL local sem WhatsApp real).
# false = bate de fato na Evolution API.
DRY_RUN_WHATSAPP=true

# URL onde a Evolution API esta rodando (pelo docker-compose, "http://evolution:8080" pelo network interno).
# Em dev local: http://localhost:8080
EVOLUTION_API_URL=http://localhost:8080
# Chave global da Evolution (a `AUTHENTICATION_API_KEY` do servico evolution).
EVOLUTION_API_KEY=substitua_pela_api_key_da_evolution
# Nome da instance criada no painel da Evolution (ex: "varbolao").
EVOLUTION_INSTANCE=varbolao
# Token estatico opcional pra validar requests do webhook (header `x-evolution-token`).
# Se vazio, nenhuma validacao adicional alem de NODE_ENV=development.
EVOLUTION_WEBHOOK_TOKEN=

# ====== API de Futebol ======
# "fifa-2026" = usa JSON local com fixtures da Copa 2026 + scraping de placares
# "mock" = 3 jogos fake pra debug rapido
FOOTBALL_PROVIDER=fifa-2026
FOOTBALL_API_KEY=mock
FOOTBALL_API_URL=https://www.api-futebol.com.br/v1

# ====== PIX (DESATIVADO — bolao esta gratuito) ======
# Quando reativar, mude PIX_VALOR_CENTAVOS pra 9990 e PIX_PROVIDER pra mercadopago/gerencianet.
PIX_PROVIDER=mock
PIX_ACCESS_TOKEN=
PIX_CHAVE=contato@vardobolao.com.br
PIX_VALOR_CENTAVOS=0

# ====== Bot ======
BOT_PREFIX=!
TIMEZONE=America/Sao_Paulo
DEFAULT_CAMPEONATO=copa-2026-fase-grupos
HORARIO_ENVIO_JOGOS_DIA=09:00
