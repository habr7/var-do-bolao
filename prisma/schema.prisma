generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================
// USUARIO — Qualquer pessoa que conversa com o bot
// ============================================
model Usuario {
  id            String   @id @default(uuid())
  whatsappId    String   @unique // wa_id da Meta (so digitos, ex: 5511999999999)
  nome          String // pushName do WhatsApp Business
  telefone      String   @unique // igual ao whatsappId em geral (mantido pra clareza)
  // ----- Canal Telegram (multi-canal, v3.59.0) -----
  // chat.id do Telegram (numerico, guardado como string). Setado no onboarding
  // quando a pessoa informa o WhatsApp dela e a gente liga o cadastro existente
  // (recuperando pontuacao/palpites). Unique: 1 conta Telegram por usuario.
  telegramId       String? @unique
  telegramUsername String? // @username do Telegram (informativo)
  // Canal preferido de ENTREGA quando AMBOS estao ligados: 'whatsapp' | 'telegram'.
  // null = decide pelas flags globais (ENABLE_WHATSAPP/ENABLE_TELEGRAM).
  canalPreferido   String?
  // Bolao padrao do usuario (ISSUE-016). Quando setado, comandos como
  // "ranking", "meus pontos", "quando comeca" pulam a etapa de escolha
  // entre N boloes — usam direto este. Nullable: opt-in do usuario.
  bolaoPadraoId String?
  criadoEm      DateTime @default(now())
  atualizadoEm  DateTime @updatedAt

  participacoes          Participacao[]
  palpites               Palpite[]
  pagamentos             Pagamento[]
  boloesAdministrados    Bolao[]                @relation("BolaoAdmin")
  solicitacoesFeitas     SolicitacaoEntrada[]
  bolaoPadrao            Bolao?                 @relation("BolaoPadrao", fields: [bolaoPadraoId], references: [id])
  mensagensNaoEntendidas MensagemNaoEntendida[]

  @@map("usuarios")
}

// ============================================
// BOLAO — Bolao privado, protegido por senha
// ============================================
model Bolao {
  id             String      @id @default(uuid())
  // Codigo curto publico (6 chars alfanum sem chars confundiveis: ex: "K3MZ8P").
  // Usado pra entrar no bolao sem ambiguidade ("nomes parecidos" risco zero).
  // O usuario manda "entrar #K3MZ8P" ou cola a mensagem-convite gerada na
  // criacao, e o bot identifica o bolao certo. Unique globalmente.
  codigo         String      @unique
  nome           String // Nome visivel ("Bolao da Firma")
  senhaHash      String // bcrypt hash da senha que participantes usam pra entrar
  adminId        String // Usuario criador
  campeonatoId   String // ID do campeonato na API de futebol
  campeonatoNome String // Ex: "Brasileirao Serie A 2026"
  status         StatusBolao @default(ATIVO)
  regras         Json? // Regras customizadas em JSON
  pagamentoId    String?     @unique // Pagamento que originou o bolao
  criadoEm       DateTime    @default(now())
  atualizadoEm   DateTime    @updatedAt

  admin              Usuario              @relation("BolaoAdmin", fields: [adminId], references: [id])
  pagamento          Pagamento?           @relation(fields: [pagamentoId], references: [id])
  participacoes      Participacao[]
  rodadas            Rodada[]
  solicitacoes       SolicitacaoEntrada[]
  // Usuarios que setaram este bolao como padrao (ISSUE-016)
  usuariosComoPadrao Usuario[]            @relation("BolaoPadrao")

  @@unique([adminId, nome])
  @@map("boloes")
}

enum StatusBolao {
  ATIVO
  PAUSADO
  FINALIZADO
}

// ============================================
// PAGAMENTO — Cobranca PIX para criacao de bolao
// ============================================
model Pagamento {
  id                       String          @id @default(uuid())
  usuarioId                String
  valorCentavos            Int             @default(9990) // R$ 99,90
  status                   PagamentoStatus @default(PENDENTE)
  pixExternalId            String?         @unique // ID retornado pelo provider PIX
  pixCopiaCola             String?         @db.Text
  pixQrCodeUrl             String?         @db.Text
  nomeBolaoPretendido      String
  senhaBolaoHashPretendido String
  pagoEm                   DateTime?
  expiraEm                 DateTime
  criadoEm                 DateTime        @default(now())
  atualizadoEm             DateTime        @updatedAt

  usuario Usuario @relation(fields: [usuarioId], references: [id])
  bolao   Bolao?

  @@index([status, expiraEm])
  @@map("pagamentos")
}

enum PagamentoStatus {
  PENDENTE
  PAGO
  EXPIRADO
  CANCELADO
}

// ============================================
// SOLICITACAO_ENTRADA — Pedido pendente de aprovacao pelo admin
// ============================================
model SolicitacaoEntrada {
  id           String            @id @default(uuid())
  usuarioId    String
  bolaoId      String
  status       SolicitacaoStatus @default(PENDENTE)
  respondidoEm DateTime?
  criadoEm     DateTime          @default(now())

  usuario Usuario @relation(fields: [usuarioId], references: [id])
  bolao   Bolao   @relation(fields: [bolaoId], references: [id])

  @@index([bolaoId, status])
  @@map("solicitacoes_entrada")
}

enum SolicitacaoStatus {
  PENDENTE
  APROVADA
  RECUSADA
}

// ============================================
// PARTICIPACAO — Relacao Usuario <-> Bolao
// ============================================
model Participacao {
  id             String   @id @default(uuid())
  usuarioId      String
  bolaoId        String
  pontuacaoTotal Int      @default(0)
  posicaoAtual   Int      @default(0)
  entradaEm      DateTime @default(now())

  usuario Usuario @relation(fields: [usuarioId], references: [id])
  bolao   Bolao   @relation(fields: [bolaoId], references: [id])

  @@unique([usuarioId, bolaoId])
  @@map("participacoes")
}

// ============================================
// RODADA — Uma rodada do campeonato
// ============================================
model Rodada {
  id             String       @id @default(uuid())
  bolaoId        String
  numero         Int
  status         StatusRodada @default(ABERTA)
  // Fase do torneio. GRUPOS = comportamento atual (default p/ não regredir as
  // rodadas de grupos já existentes). Mata-mata usa as demais fases.
  fase           FaseTorneio  @default(GRUPOS)
  dataAbertura   DateTime
  dataFechamento DateTime
  criadoEm       DateTime     @default(now())

  bolao    Bolao     @relation(fields: [bolaoId], references: [id])
  jogos    Jogo[]
  palpites Palpite[]

  @@unique([bolaoId, numero])
  // v3.28.0 — hot path: rodadas ABERTAS por bolão (fetch-results/bom-dia).
  @@index([bolaoId, status])
  @@map("rodadas")
}

enum StatusRodada {
  ABERTA
  FECHADA
  FINALIZADA
}

// ============================================
// FASE_TORNEIO — Fase da Copa (grupos + mata-mata)
// ============================================
// GRUPOS é o default em Rodada/Jogo, garantindo que toda a fase de grupos já
// apurada (produção) continue com o comportamento atual. As fases de mata-mata
// (R32=16-avos … FINAL) sobem os valores de placar e ligam o bônus de
// classificado. TERCEIRO = disputa de 3º lugar.
enum FaseTorneio {
  GRUPOS
  R32
  OITAVAS
  QUARTAS
  SEMI
  TERCEIRO
  FINAL
}

// Lado de um confronto de mata-mata. Serve a DOIS usos: (1) qual lado o usuário
// crava como classificado (bônus); (2) qual slot o vencedor ocupa no próximo
// jogo da chave (auto-advance).
enum LadoJogo {
  CASA
  VISITANTE
}

// ============================================
// JOGO — Um jogo dentro de uma rodada
// ============================================
model Jogo {
  id            String     @id @default(uuid())
  rodadaId      String
  // apiJogoId NAO eh mais unique global — o adapter FIFA 2026 retorna
  // sempre os mesmos 72 IDs (WC2026_A_1..) pra qualquer bolao, entao
  // unique global quebrava do 2o bolao em diante com P2002. Agora a
  // unicidade eh por rodada (que ja garante isolamento entre bolaes).
  apiJogoId     String
  timeCasa      String
  timeVisitante String
  golsCasa      Int?
  golsVisitante Int?
  status        StatusJogo @default(AGENDADO)
  dataHora      DateTime
  criadoEm      DateTime   @default(now())
  atualizadoEm  DateTime   @updatedAt

  // ----- Campos de mata-mata (todos nullable/com default — migration aditiva) -----
  // Fase do jogo. GRUPOS = default (jogos de grupos existentes ficam intactos).
  fase                FaseTorneio @default(GRUPOS)
  // Quem avançou (resultado real). Alimenta o bônus de classificado E a chave.
  // Placar GRAVADO é sempre 90'+prorrogação; pênalti só define este campo.
  classificadoLado    LadoJogo?
  // Verdade só em jogo decidido na disputa de pênaltis (placar empatou no fim
  // da prorrogação). Apenas informativo/UX — não entra no placar do bolão.
  decididoNosPenaltis Boolean?
  // apiJogoId do jogo seguinte na chave (de bracket-2026.ts). Null em grupos/final.
  proximoJogoApiId    String?
  // Em qual lado (CASA/VISITANTE) o vencedor deste jogo entra no próximo.
  proximoSlot         LadoJogo?

  rodada       Rodada        @relation(fields: [rodadaId], references: [id])
  palpitesJogo PalpiteJogo[]

  @@unique([rodadaId, apiJogoId])
  @@index([dataHora])
  @@map("jogos")
}

enum StatusJogo {
  AGENDADO
  AO_VIVO
  FINALIZADO
  ADIADO
  CANCELADO
}

// ============================================
// PALPITE — Conjunto de palpites de um usuario para uma rodada
// ============================================
model Palpite {
  id           String   @id @default(uuid())
  usuarioId    String
  rodadaId     String
  pontuacao    Int      @default(0)
  calculado    Boolean  @default(false)
  criadoEm     DateTime @default(now())
  atualizadoEm DateTime @updatedAt

  usuario Usuario       @relation(fields: [usuarioId], references: [id])
  rodada  Rodada        @relation(fields: [rodadaId], references: [id])
  jogos   PalpiteJogo[]

  @@unique([usuarioId, rodadaId])
  // v3.28.0 — hot path do calculate-scores: rodadas com palpite calculado=false.
  @@index([rodadaId, calculado])
  @@map("palpites")
}

// ============================================
// PALPITE_JOGO — Palpite individual por jogo
// ============================================
model PalpiteJogo {
  id            String @id @default(uuid())
  palpiteId     String
  jogoId        String
  golsCasa      Int
  golsVisitante Int
  // pontosObtidos = SÓ os pontos de placar (faixa por fase). O bônus de
  // classificado fica em bonusObtido (coluna separada) pra não poluir a
  // bucketização por faixa de getEstatisticaPontos/getJogosPorFaixa.
  pontosObtidos Int    @default(0)
  // Lado que o usuário cravou como classificado. Exigido SÓ quando o palpite é
  // empate num jogo de mata-mata (decisivo → classificado é inferido do vencedor).
  classificadoPalpite LadoJogo?
  // Bônus de classificado ganho neste jogo (aditivo ao placar). 0 em grupos.
  bonusObtido         Int       @default(0)

  palpite Palpite @relation(fields: [palpiteId], references: [id])
  jogo    Jogo    @relation(fields: [jogoId], references: [id])

  @@unique([palpiteId, jogoId])
  @@map("palpites_jogos")
}

// ============================================
// MENSAGEM_NAO_ENTENDIDA — historico persistente pra melhorar o bot
// ============================================
// Substitui a antiga lista Redis (metrics:YYYY-MM-DD:nao-entendi). Persistencia
// permanente queryable via SQL — pra revisar mensagens que cairam fora de
// regex/LLM e identificar variantes novas a virar handler.
//
// Captura 4 motivos:
//   - regex_fail: parser regex nao casou nada (default antes de tentar LLM)
//   - llm_fail: LLM intent classifier retornou null (deu erro / sem resposta)
//   - final_fallback: tudo falhou, bot mostrou "nao entendi" generico
//   - low_confidence: LLM tentou classificar mas confianca < 0.55 (ouro pra
//     descobrir variantes que merecem virar regex)
//
// LGPD: whatsappId NUNCA persistido em claro — so hash sha256-16. usuarioId eh
// FK opcional (ON DELETE SET NULL — se usuario deletar conta, log perde
// linkagem mas mensagem fica como dado anonimo).
//
// TTL: removido pelo job mensal `limpar-mensagens-antigas` (default 180 dias,
// configuravel via MENSAGEM_NAO_ENTENDIDA_RETENCAO_DIAS).
model MensagemNaoEntendida {
  id             String   @id @default(uuid())
  usuarioId      String?
  whatsappIdHash String // SHA-256(whatsappId).slice(0,16)
  texto          String   @db.Text // truncado em 500 chars
  state          String // estado FSM no momento ("IDLE", "CONFIRMANDO_*", etc)
  motivo         String // 'regex_fail' | 'llm_fail' | 'final_fallback' | 'low_confidence'
  llmIntent      String? // intent que o LLM tentou (mesmo low-conf)
  llmConfianca   Float? // 0-1
  criadoEm       DateTime @default(now())

  usuario Usuario? @relation(fields: [usuarioId], references: [id], onDelete: SetNull)

  @@index([criadoEm])
  @@index([motivo, criadoEm])
  @@map("mensagens_nao_entendidas")
}
