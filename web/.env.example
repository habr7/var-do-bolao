# ====== App ======
NODE_ENV=development
NEXT_PUBLIC_SITE_URL=http://localhost:3001

# Numero do bot no WhatsApp (formato com codigo do pais, sem mascara)
# Usado pra montar links wa.me dos CTAs ("Criar bolao no WhatsApp")
NEXT_PUBLIC_BOT_WHATSAPP_NUMBER=5511978277516

# ====== Backend (Fastify do bot) ======
# O Next chama o bot via fetch SSR (server-side). O cookie de sessao
# eh setado pelo bot e re-encaminhado pelo Next pro browser.
# Em prod use rede interna Railway: http://var-do-bolao.railway.internal:3000
BOT_API_URL=http://localhost:3000

# O bot precisa estar com WEB_API_ENABLED=true pra essas rotas existirem.
